{
	email {env.ADMIN_EMAIL}
}

(production_config) {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=2629800; includeSubDomains"
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Content-Security-Policy "frame-ancestors 'self';"

		-Server
		-Via
	}
}

(tls_config) {
	tls {
		dns cloudflare {env.CF_API_TOKEN}
		propagation_timeout 3m
		propagation_delay 1m
		resolvers 1.1.1.1
	}
}

(common_proxy_headers) {
	header_up Host {http.request.host}
	header_up X-Real-IP {http.request.remote.host}
}

(internal_cors) {
	@homeOrigin header_regexp Origin ^https://([a-z0-9-]+\.)?{$INTERNAL_CORS_ORIGIN_ESCAPED_DOMAIN}(:\d+)?$

	header @homeOrigin Access-Control-Allow-Origin "{http.request.header.Origin}"
	header @homeOrigin Access-Control-Allow-Credentials "true"
	header @homeOrigin Access-Control-Allow-Methods "GET, POST, PUT, DELETE, PATCH, OPTIONS"
	header @homeOrigin Access-Control-Allow-Headers "{http.request.header.Access-Control-Request-Headers}"
	header @homeOrigin Vary "Origin"
}

:8081 {
	respond "OK" 200
}

(routes) {
	@wg-easy expression {host}.startsWith("wg-easy")
	handle @wg-easy {
		reverse_proxy http://wireguard.vm:51821 {
			import common_proxy_headers
		}
	}

	@video-converter expression {host}.startsWith("video-converter")
	handle @video-converter {
		reverse_proxy http://video-converter.vm:8080 {
			import common_proxy_headers
			flush_interval -1
		}
	}

	@insights expression {host}.startsWith("insights")
	handle @insights {
		reverse_proxy http://insights.vm:8080 {
			import common_proxy_headers
			flush_interval -1
		}
	}

	@stirling-pdf expression {host}.startsWith("stirling-pdf")
	handle @stirling-pdf {
		reverse_proxy http://stirling-pdf.vm:8080 {
			import common_proxy_headers
			flush_interval -1
		}
	}

	@ollama expression {host}.startsWith("ollama")
	handle @ollama {
		reverse_proxy http://ollama.vm:8080 {
			import common_proxy_headers
			flush_interval -1
		}
	}

	@n8n expression {host}.startsWith("n8n")
	handle @n8n {
		import internal_cors

		reverse_proxy http://n8n.vm:8080 {
			import common_proxy_headers
			flush_interval -1
		}
	}

	@odoo expression {host}.startsWith("odoo")
	handle @odoo {
		reverse_proxy http://odoo.vm:8080 {
			import common_proxy_headers
		}
	}

	@convertx expression {host}.startsWith("convertx")
	handle @convertx {
		reverse_proxy http://convertx.vm:8080 {
			import common_proxy_headers
		}
	}

	@immich expression {host}.startsWith("immich")
	handle @immich {
		import internal_cors

		reverse_proxy http://immich.vm:8080 {
			import common_proxy_headers
		}
	}

	@erpnext expression {host}.startsWith("erpnext")
	handle @erpnext {
		reverse_proxy http://erpnext.vm:8080 {
			import common_proxy_headers
		}
	}

	@dolibarr expression {host}.startsWith("dolibarr")
	handle @dolibarr {
		reverse_proxy http://dolibarr.vm:8080 {
			import common_proxy_headers
		}
	}

	@jellyseerr expression {host}.startsWith("jellyseerr")
	handle @jellyseerr {
		reverse_proxy http://arr.vm:5055 {
			import common_proxy_headers
		}
	}

	@mediamanager expression {host}.startsWith("mediamanager")
	handle @mediamanager {
		reverse_proxy http://mediamanager.vm:8080 {
			import common_proxy_headers
		}
	}

	@ghost expression {host}.startsWith("ghost")
	handle @ghost {
		handle /.ghost/activitypub/* {
			reverse_proxy http://ghost.vm:8080
		}

		handle /.well-known/webfinger {
			reverse_proxy http://ghost.vm:8080
		}

		handle /.well-known/nodeinfo {
			reverse_proxy http://ghost.vm:2368
		}

		reverse_proxy http://ghost.vm:2368 {
			import common_proxy_headers
		}
	}

	handle {
		respond "Not Found" 404
	}
}

jellyfin.home.{$DOMAIN_NAME} {
	import tls_config
	
	reverse_proxy http://jellyfin.vm:8080 {
		import common_proxy_headers
		flush_interval -1
	}
}

*.home.{$DOMAIN_NAME} *.{$DOMAIN_NAME} {
	import production_config
	import tls_config
	import routes
}
