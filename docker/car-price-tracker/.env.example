TIMEZONE=Europe/Zurich

# Database
POSTGRES_USER=cartracker
POSTGRES_PASSWORD=cartracker
POSTGRES_DB=cartracker

# App
BASE_URL=https://www.example.com
SCRAPE_INTERVAL_HOURS=24
RETRY_INTERVAL_HOURS=6
MAX_PAGES_PER_FILTER=200

# Browserless sidecar used by Docker Compose. Use a URL-safe value because
# the token is passed in a query string, for example: openssl rand -hex 32
BROWSERLESS_TOKEN=replace-with-a-random-url-safe-token
BROWSERLESS_TIMEOUT_MS=3600000
BROWSERLESS_CONCURRENT=1

# Optional for non-Docker backend runs. Docker Compose sets the sidecar
# endpoint directly from BROWSERLESS_TOKEN.
# CDP_ENDPOINT=
