{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "helpers:pinGitHubActionDigestsToSemver"
  ],
  "schedule": ["after 8pm on sunday"],
  "packageRules": [
    {
      "matchDatasources": ["github-actions"],
      "groupName": "github actions",
      "groupSlug": "github-actions"
    },
    {
      "description": "Group Non-Major updates for Dockerfiles by filename",
      "matchManagers": ["dockerfile"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "groupName": "Non-major updates for {{packageFile}}"
    },
    {
      "description": "Group Major updates for Dockerfiles by filename",
      "matchManagers": ["dockerfile"],
      "matchUpdateTypes": ["major"],
      "groupName": "Major updates for {{packageFile}}"
    },
    {
      "description": "Group Non-Major updates for Docker Compose by filename",
      "matchManagers": ["docker-compose"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "groupName": "Non-major updates for {{packageFile}}"
    },
    {
      "description": "Group Major updates for Docker Compose by filename",
      "matchManagers": ["docker-compose"],
      "matchUpdateTypes": ["major"],
      "groupName": "Major updates for {{packageFile}}"
    }
  ]
}
