profile: production


# We want to catch everything, but exclude some non-ansible stuff if needed
exclude_paths:
  - .github/
  - .git/
  - docs/
  - docker/
  - proxmox/

# Mock modules if they are not available locally (e.g. community.docker if not installed)
# mock_modules:
#   - community.docker.docker_compose_v2

# Configure verbosity
verbosity: 1
